#!/usr/bin/env bash
# Run the full test suite: backend pytest then frontend Playwright E2E.
#
# Usage (from repo root):
#   bash scripts/test
#
# Prerequisites:
#   - secrets/jwt_private_key.pem and secrets/jwt_public_key.pem must exist
#   - The FastAPI backend must be running on http://localhost:8080
#   - Playwright Chromium must be installed (npx playwright install chromium)

set -e  # exit immediately if any command fails

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

echo ""
echo "================================================"
echo "  [1/2] Backend unit tests (pytest)"
echo "================================================"
cd "$REPO_ROOT/backend"
pytest

echo ""
echo "================================================"
echo "  [2/2] Frontend E2E tests (Playwright)"
echo "  Assumes backend is running on http://localhost:8080"
echo "================================================"
cd "$REPO_ROOT/frontend"
npm run test:e2e

echo ""
echo "================================================"
echo "  All tests passed."
echo "================================================"
